# FitLife Environment Variables
# Copy to .env and fill in your actual values
# NEVER commit .env to version control

# ── Frontend (Vite) ──────────────────────────────────
# These are exposed to the browser (prefixed with VITE_)

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# App Configuration
VITE_APP_URL=http://localhost:3000

# ── Server-side Only (Vercel) ─────────────────────────
# Set these in Vercel Dashboard → Settings → Environment Variables
# They are NEVER exposed to the browser

# Google AI (Gemini) for nutrition plan generation
# Used by /api/ai-nutrition and /api/ai-chat serverless functions
GOOGLE_AI_API_KEY=your-google-ai-key
